# Copy this block into provider.tf (replace backend "s3" comment)
# Create these AWS resources first (one-time setup):

# aws s3api create-bucket --bucket YOUR-UNIQUE-STATE-BUCKET --region us-east-1
# aws dynamodb create-table \
#   --table-name terraform-state-lock \
#   --attribute-definitions AttributeName=LockID,AttributeType=S \
#   --key-schema AttributeName=LockID,KeyType=HASH \
#   --billing-mode PAY_PER_REQUEST

terraform {
  backend "s3" {
    bucket         = "your-unique-terraform-state-bucket"
    key            = "cloud-notes-app/terraform.tfstate"
    region         = "us-east-1"
    dynamodb_table = "terraform-state-lock"
    encrypt        = true
  }
}
